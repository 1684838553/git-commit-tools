{
  "name": "git-commit-tools",
  "displayName": "Git Commit Tools",
  "description": "Edit commit messages and squash arbitrary commits, inspired by CLion",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitCommitTools.editCommitMessage",
        "title": "Git: Edit Commit Message"
      },
      {
        "command": "gitCommitTools.squashCommits",
        "title": "Git: Squash Commits"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
